# Variables de entorno — MMO Cursos Backend
# Copia este archivo como .env y ajusta los valores

JWT_SECRET=mmo_jwt_secret_cambiar_en_produccion
JWT_EXPIRES_IN=24h

# ── Almacenamiento de objetos ──────────────────────────────────────
# STORAGE_PROVIDER: "local" (stub sin MinIO), "minio", "s3"
STORAGE_PROVIDER=minio

# Hostname y credenciales de MinIO
MINIO_ENDPOINT=minio           # hostname interno Docker (minio:9000)
MINIO_PUBLIC_ENDPOINT=localhost # hostname accesible desde el navegador (dev: localhost, prod: tu dominio)
MINIO_PORT=9000
MINIO_PUBLIC_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=mmo-cursos
MINIO_USE_SSL=false
